<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <EditText
        android:id="@+id/edtNomeEvento"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Nome do evento"/>

    <EditText
        android:id="@+id/edtDescricaoEvento"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Descrição"
        android:layout_marginTop="12dp"/>

    <EditText
        android:id="@+id/edtDataEvento"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Data do evento"
        android:layout_marginTop="12dp"/>

    <EditText
        android:id="@+id/edtVagasEvento"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Quantidade de vagas"
        android:inputType="number"
        android:layout_marginTop="12dp"/>

</LinearLayout>