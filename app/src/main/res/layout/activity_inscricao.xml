<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F172A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- BOTÃO VOLTAR -->
        <ImageButton
            android:id="@+id/btnVoltar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@android:color/transparent"
            android:src="@android:drawable/ic_media_previous"
            android:tint="@android:color/white" />

        <!-- TÍTULO -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ficha de Inscrição"
            android:textColor="@android:color/white"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="24dp" />

        <!-- CARD EVENTO -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1E293B"
            android:padding="20dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Evento Selecionado"
                android:textColor="#94A3B8"
                android:textStyle="bold"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txtEvento"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nome do Evento"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:textSize="24sp"
                android:layout_marginTop="8dp" />

        </LinearLayout>

        <!-- COFFEE BREAK -->
        <CheckBox
            android:id="@+id/checkCoffee"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Desejo participar do Coffee Break"
            android:textColor="@android:color/white"
            android:buttonTint="#2563EB"
            android:layout_marginBottom="32dp" />

        <!-- BOTÃO -->
        <Button
            android:id="@+id/btnInscrever"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Confirmar Inscrição"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:backgroundTint="#2563EB" />

    </LinearLayout>

</ScrollView>