<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F172A">

    <!-- SCROLL -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="48dp"
            android:paddingBottom="24dp">

            <!-- TOPO -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp">

                <!-- VOLTAR -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnVoltar"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:text="←"
                    android:textSize="18sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#2563EB"
                    app:cornerRadius="14dp"/>

                <!-- TITULO -->
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Localização"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="28sp"
                    android:gravity="center"/>
            </LinearLayout>

            <!-- SUBTITULO -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Confira onde acontecerá o evento WeekTech 2026"
                android:textColor="#CBD5E1"
                android:textSize="16sp"
                android:gravity="center"
                android:layout_marginBottom="24dp"/>

            <!-- CARD -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:backgroundTint="#1E293B"
                app:cardCornerRadius="24dp"
                app:cardElevation="10dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <!-- IMAGEM -->
                    <ImageView
                        android:id="@+id/imgLocal"
                        android:layout_width="match_parent"
                        android:layout_height="220dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/unicesumar"
                        android:adjustViewBounds="true"
                        android:background="#FFFFFF"/>

                    <!-- NOME -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="UniCesumar Londrina"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="24sp"
                        android:layout_marginTop="20dp"/>

                    <!-- ENDEREÇO -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Av. Santa Mônica, 450 - Franca, Londrina - PR"
                        android:textColor="#CBD5E1"
                        android:textSize="16sp"
                        android:layout_marginTop="8dp"/>

                    <!-- DESCRIÇÃO -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="O evento acontecerá no campus da UniCesumar Londrina com palestras, workshops e networking."
                        android:textColor="#E2E8F0"
                        android:textSize="15sp"
                        android:lineSpacingExtra="4dp"
                        android:layout_marginTop="18dp"/>

                    <!-- BOTÃO MAPS -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnMaps"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="24dp"
                        android:text="Abrir no Google Maps"
                        android:textAllCaps="false"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#2563EB"
                        app:cornerRadius="18dp"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>